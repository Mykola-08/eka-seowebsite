# HubSpot Integration
# Portal ID (public — used client-side for tracking script & forms)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=

# Private App access token (server-side only — for CRM API calls)
# Create at: Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.write, forms
HUBSPOT_ACCESS_TOKEN=

# Optional: HubSpot form GUID for embedded contact form
NEXT_PUBLIC_HUBSPOT_CONTACT_FORM_GUID=

# Feature flag to enable/disable HubSpot tracking (default: true)
NEXT_PUBLIC_HUBSPOT_TRACKING_ENABLED=true
